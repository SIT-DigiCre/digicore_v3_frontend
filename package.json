{
  "private": true,
  "scripts": {
    "build": "next typegen && next build",
    "codecheck": "pnpm lint && pnpm format",
    "dev": "next",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "generate": "npx openapi-typescript ./src/utils/fetch/bundle.gen.yml -o ./src/utils/fetch/api.d.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preinstall": "npx only-allow pnpm",
    "prepare": "lefthook install",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "dayjs": "1.11.20",
    "isomorphic-dompurify": "3.5.1",
    "marked": "17.0.4",
    "next": "16.1.7",
    "openapi-fetch": "0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "lefthook": "2.1.4",
    "openapi-typescript": "7.13.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
